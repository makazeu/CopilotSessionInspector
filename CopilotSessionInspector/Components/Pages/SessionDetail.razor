@page "/session/{Id}"
@rendermode InteractiveServer
@inject SessionAnalysisService Analysis
@inject IJSRuntime JS

<PageTitle>Session - Copilot Session Inspector</PageTitle>

<p><a href="sessions">&laquo; Back to sessions</a></p>

@if (_analysis is null)
{
    @if (_loading)
    {
        <p><em>Analyzing session…</em></p>
    }
    else
    {
        <div class="alert alert-warning">Session <code>@Id</code> was not found.</div>
    }
}
else
{
    var a = _analysis;
    <h1 class="h3">@a.Session.DisplayName</h1>
    <p class="text-muted small font-monospace mb-1">@a.Session.Id</p>
    <p class="small">
        @if (a.Session.Repository is not null) { <span class="me-3"><strong>Repo:</strong> @a.Session.Repository</span> }
        @if (a.Session.Cwd is not null) { <span class="me-3"><strong>Dir:</strong> @a.Session.Cwd</span> }
        @if (a.Session.CreatedAt is not null) { <span class="me-3"><strong>Created:</strong> @a.Session.CreatedAt?.ToLocalTime().ToString("g")</span> }
        @if (a.Session.UpdatedAt is not null) { <span class="me-3"><strong>Updated:</strong> @a.Session.UpdatedAt?.ToLocalTime().ToString("g")</span> }
    </p>

    @* ---- Summary stat cards ---- *@
    <div class="row row-cols-2 row-cols-md-4 row-cols-xl-6 g-2 my-2">
        @Stat("Turns", a.TurnCount.ToString("N0"), "Number of user prompts in the session. Each turn begins when you send a message and includes every agent reply and tool call until the agent finishes responding.")
        @Stat("API calls", a.ApiCallCount.ToString("N0"), "Total model inference requests sent to the LLM across the whole session. A single turn usually triggers many API calls (one per agent step / tool round-trip).")
        @Stat("Total tokens", a.TotalTokens.ToString("N0"), "Sum of input + output tokens across all API calls. Tokens are the unit the model reads and writes; more tokens generally mean higher cost and latency.")
        @Stat("Input tokens", a.TotalInputTokens.ToString("N0"), "Tokens sent TO the model (your prompt, system instructions, prior conversation, tool results). This is the dominant cost driver as the conversation grows.")
        @Stat("Output tokens", a.TotalOutputTokens.ToString("N0"), "Tokens generated BY the model — its replies and tool-call requests (excludes hidden reasoning tokens, which are counted separately).")
        @Stat("Reasoning tokens", a.TotalReasoningTokens.ToString("N0"), "Tokens the model spent on internal chain-of-thought before producing its answer. Billed as output but not shown in the visible reply.")
        @Stat("AI units (AIU)", a.TotalAiu.ToString("N1"), "AI Units consumed — a fine-grained usage metric from telemetry (total_nano_aiu ÷ 1,000,000,000), summed over all API calls.")
        @Stat("Premium cost", a.TotalCost.ToString("N1"), "GitHub Copilot premium-request quota consumed (the metered billing unit), summed from each call's telemetry cost. Each model has a multiplier; this is NOT a dollar amount.")
        @Stat("Session time", a.SessionDurationMs > 0 ? FormatDuration(a.SessionDurationMs) : "—", "Sum of each turn's elapsed time, from your prompt to the last recorded agent/tool event in that turn. Excludes idle gaps between turns.")
        @Stat("API time", FormatDuration(a.TotalApiDurationMs), "Total wall-clock time spent waiting on model inference (sum of each API call's duration). Excludes tool-execution time.")
        @Stat("Tool calls", a.TotalToolCalls.ToString("N0"), "Number of tool/operation invocations the agent ran (file reads, edits, shell commands, searches, etc.).")
        @Stat("Tool time", FormatDuration(a.TotalToolDurationMs), "Total wall-clock time spent executing tools (running commands, reading/writing files, etc.). Excludes model inference time.")
        @Stat("Peak context", a.ContextLimit > 0 ? $"{a.PeakContextTokens:N0} / {a.ContextLimit:N0}" : "—", "Largest context-window fill reached during the session (current tokens / model's token limit). Nearing the limit triggers compaction and can raise cost.")
        @Stat("Cache reads", a.CacheReadTokens.ToString("N0"), "Input tokens served from the prompt cache instead of being re-processed. Cache hits are cheaper and faster than uncached input tokens.")
    </div>

    @* ---- Suggestions ---- *@
    <h2 class="h5 mt-4">Cost-reduction suggestions</h2>
    @foreach (var s in a.Suggestions)
    {
        <div class="alert @AlertClass(s.Severity) py-2 mb-2">
            <strong>@s.Title</strong>
            <div class="small">@s.Detail</div>
        </div>
    }

    @* ---- Charts ---- *@
    @if (a.HasTelemetry)
    {
        <h2 class="h5 mt-4">Charts</h2>
        <div class="row">
            <div class="col-lg-6 mb-4">
                <div class="card h-100"><div class="card-body">
                    <h6 class="card-title">Tokens per turn</h6>
                    <div style="position:relative;height:280px;"><canvas id="chartTokens"></canvas></div>
                </div></div>
            </div>
            <div class="col-lg-6 mb-4">
                <div class="card h-100"><div class="card-body">
                    <h6 class="card-title">Cumulative AIU &amp; time</h6>
                    <div style="position:relative;height:280px;"><canvas id="chartCumulative"></canvas></div>
                </div></div>
            </div>
            @if (a.ContextSamples.Count > 1)
            {
                <div class="col-lg-12 mb-4">
                    <div class="card"><div class="card-body">
                        <h6 class="card-title">Context window growth</h6>
                        <div style="position:relative;height:260px;"><canvas id="chartContext"></canvas></div>
                    </div></div>
                </div>
            }
        </div>

        @* ---- Model breakdown ---- *@
        <h2 class="h5 mt-2">By model</h2>
        <div class="table-responsive">
        <table class="table table-sm">
            <thead><tr>
                <th>Model</th><th class="text-end">Calls</th><th class="text-end">Input</th>
                <th class="text-end">Output</th><th class="text-end">AIU</th><th class="text-end">Cost</th><th class="text-end">Time</th>
            </tr></thead>
            <tbody>
                @foreach (var m in a.ModelBreakdowns)
                {
                    <tr>
                        <td class="font-monospace">@m.Model</td>
                        <td class="text-end">@m.Calls</td>
                        <td class="text-end">@m.InputTokens.ToString("N0")</td>
                        <td class="text-end">@m.OutputTokens.ToString("N0")</td>
                        <td class="text-end">@m.Aiu.ToString("N1")</td>
                        <td class="text-end">@m.Cost.ToString("N1")</td>
                        <td class="text-end">@FormatDuration(m.DurationMs)</td>
                    </tr>
                }
            </tbody>
        </table>
        </div>

        @if (a.TotalToolCalls > 0)
        {
            <h2 class="h5 mt-2">Tools / operations used</h2>
            <div class="table-responsive">
            <table class="table table-sm">
                <thead><tr>
                    <th>Tool</th><th class="text-end">Calls</th><th class="text-end">Failures</th><th class="text-end">Time</th>
                </tr></thead>
                <tbody>
                    @foreach (var tb in a.ToolBreakdowns)
                    {
                        <tr>
                            <td class="font-monospace">@tb.ToolName</td>
                            <td class="text-end">@tb.Calls</td>
                            <td class="text-end">@(tb.Failures > 0 ? tb.Failures.ToString() : "—")</td>
                            <td class="text-end">@FormatDuration(tb.DurationMs)</td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        }
    }
    else
    {
        <div class="alert alert-secondary">No token telemetry available for this session — showing the reconstructed conversation only.</div>
    }

    @* ---- Timeline ---- *@
    <div class="d-flex justify-content-between align-items-center mt-4 mb-2">
        <h2 class="h5 mb-0">Session timeline</h2>
        <div class="btn-group btn-group-sm" role="group">
            <button type="button" class="btn btn-outline-secondary" @onclick="() => SetAllTurns(true)">Expand all</button>
            <button type="button" class="btn btn-outline-secondary" @onclick="() => SetAllTurns(false)">Collapse all</button>
        </div>
    </div>
    @foreach (var t in a.Timeline)
    {
        <details class="card mb-3 turn-card">
            <summary class="card-header d-flex justify-content-between align-items-center py-2">
                <span class="turn-summary-label">
                    <strong>Turn @t.TurnIndex</strong>
                    @if (t.StartTime is not null) { <span class="text-muted small ms-2">@t.StartTime?.ToLocalTime().ToString("g")</span> }
                    @if (!string.IsNullOrWhiteSpace(t.UserMessage))
                    {
                        <span class="text-muted small ms-2 turn-prompt-preview">— @Truncate(t.UserMessage, 90)</span>
                    }
                </span>
                <span class="small text-muted text-nowrap ms-2">
                    @t.AgentMessageCount reply(ies) · @t.ToolCallCount tool(s)
                    @if (t.Actions.Count > 0)
                    {
                        <text> · @t.Aiu.ToString("N1") AIU · @FormatDuration(t.DurationMs)</text>
                    }
                </span>
            </summary>
            <div class="card-body py-2">
                @if (!string.IsNullOrWhiteSpace(t.UserMessage))
                {
                    <div class="mb-2">
                        <span class="badge bg-primary">User</span>
                        <pre class="conv mt-1">@t.UserMessage</pre>
                    </div>
                }
                @if (t.Steps.Count > 0)
                {
                    <div class="mb-2">
                        <div class="small text-muted mb-1">
                            Conversation — @t.AgentMessageCount agent reply(ies), @t.ToolCallCount tool call(s)
                        </div>
                        <ul class="op-list">
                            @foreach (var step in t.Steps)
                            {
                                @if (step.IsTool)
                                {
                                    var args = StepArgs(step);
                                    var preview = StepPreview(step);
                                    var prettyArgs = PrettyArgs(args);
                                    var hasMore = !string.IsNullOrWhiteSpace(args)
                                        && (prettyArgs.Contains('\n') || prettyArgs.Length > preview.Length + 20);
                                    <li class="op-tool @(step.Failed ? "failed" : "")">
                                        <div class="op-row">
                                            <span class="op-time">@step.Time?.ToLocalTime().ToString("HH:mm:ss")</span>
                                            <span class="badge @(step.Failed ? "bg-danger" : "bg-secondary")">@step.ToolName</span>
                                            @if (step.IsMcp) { <span class="badge bg-info text-dark">MCP</span> }
                                            @if (hasMore)
                                            {
                                                <details class="op-detail args-inline">
                                                    <summary class="op-args-summary">
                                                        <code class="op-args">@preview</code><span class="op-more">more</span>
                                                    </summary>
                                                    <pre class="conv args mt-1">@prettyArgs</pre>
                                                </details>
                                            }
                                            else if (!string.IsNullOrWhiteSpace(preview))
                                            {
                                                <code class="op-args">@preview</code>
                                            }
                                            <span class="op-meta">
                                                @step.ResultType · @FormatDuration(step.DurationMs)
                                                @if (step.ResultLength > 0) { <text> · @step.ResultLength.ToString("N0") chars</text> }
                                            </span>
                                        </div>
                                        @if (step.Failed)
                                        {
                                            var reason = !string.IsNullOrWhiteSpace(step.ErrorMessage)
                                                ? step.ErrorMessage!
                                                : (!string.IsNullOrWhiteSpace(step.ResultContent) ? step.ResultContent! : "Tool call failed (no reason recorded).");
                                            <div class="op-error">
                                                <span class="op-error-label">⚠ Failed</span>
                                                @if (!string.IsNullOrWhiteSpace(step.ErrorCode)) { <span class="op-error-code">@step.ErrorCode</span> }
                                                <span class="op-error-msg">@TruncateRaw(reason, 2000)</span>
                                            </div>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(step.ResultContent))
                                        {
                                            <details class="op-detail">
                                                <summary class="small text-muted">tool result</summary>
                                                <pre class="conv result mt-1">@TruncateRaw(step.ResultContent, 4000)</pre>
                                            </details>
                                        }
                                    </li>
                                }
                                else
                                {
                                    <li class="op-agent">
                                        <div class="op-row">
                                            <span class="op-time">@step.Time?.ToLocalTime().ToString("HH:mm:ss")</span>
                                            <span class="badge bg-success">Agent</span>
                                            <span class="op-meta">
                                                @if (step.ToolRequestCount > 0) { <text>requested @step.ToolRequestCount tool(s)</text> }
                                                @if (step.OutputTokens > 0) { <text> · @step.OutputTokens.ToString("N0") out tok</text> }
                                                @if (!string.IsNullOrEmpty(step.Model)) { <text> · @step.Model</text> }
                                            </span>
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(step.Content))
                                        {
                                            <pre class="conv agent mt-1">@step.Content</pre>
                                        }
                                        else if (step.ToolRequestCount > 0)
                                        {
                                            <div class="small text-muted fst-italic">(no text — went straight to tool calls)</div>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(step.ReasoningText))
                                        {
                                            <details class="op-detail">
                                                <summary class="small text-muted">reasoning</summary>
                                                <pre class="conv reasoning mt-1">@step.ReasoningText</pre>
                                            </details>
                                        }
                                    </li>
                                }
                            }
                        </ul>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(t.AssistantResponse))
                {
                    <div class="mb-2">
                        <span class="badge bg-success">Agent — final reply</span>
                        <pre class="conv mt-1">@t.AssistantResponse</pre>
                    </div>
                }
                @if (t.Actions.Count > 0)
                {
                    <details>
                        <summary class="small text-muted">@t.Actions.Count model call(s) — token &amp; time detail</summary>
                        <table class="table table-sm mt-2 mb-0">
                            <thead><tr>
                                <th>Time</th><th>Model</th><th>Effort</th><th>Finish</th>
                                <th class="text-end">Input</th><th class="text-end">Output</th>
                                <th class="text-end">Reasoning</th><th class="text-end">AIU</th><th class="text-end">Duration</th>
                            </tr></thead>
                            <tbody>
                                @foreach (var act in t.Actions)
                                {
                                    <tr>
                                        <td class="small">@act.Timestamp?.ToLocalTime().ToString("HH:mm:ss")</td>
                                        <td class="font-monospace small">@act.Model</td>
                                        <td class="small">@act.ReasoningEffort</td>
                                        <td class="small">@act.FinishReason</td>
                                        <td class="text-end">@act.InputTokens.ToString("N0")</td>
                                        <td class="text-end">@act.OutputTokens.ToString("N0")</td>
                                        <td class="text-end">@act.ReasoningTokens.ToString("N0")</td>
                                        <td class="text-end">@act.Aiu.ToString("N2")</td>
                                        <td class="text-end">@FormatDuration(act.DurationMs)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </details>
                }
            </div>
        </details>
    }

    @if (a.Checkpoints.Count > 0)
    {
        <h2 class="h5 mt-4">Checkpoints</h2>
        <ul>
            @foreach (var c in a.Checkpoints)
            {
                <li><strong>#@c.Number @c.Title</strong> <span class="text-muted small">@c.CreatedAt?.ToLocalTime().ToString("g")</span></li>
            }
        </ul>
    }
}

@code {
    [Parameter] public string Id { get; set; } = "";

    private SessionAnalysis? _analysis;
    private bool _loading = true;
    private bool _chartsRendered;

    private async Task SetAllTurns(bool open)
        => await JS.InvokeVoidAsync("copilotUi.setAllTurns", open);

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _chartsRendered = false;
        _analysis = await Task.Run(() => Analysis.Analyze(Id));
        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_analysis is null || _chartsRendered || !_analysis.HasTelemetry) return;
        _chartsRendered = true;

        var turns = _analysis.Timeline.Where(t => t.Actions.Count > 0).ToList();
        var labels = turns.Select(t => $"#{t.TurnIndex}").ToArray();
        var input = turns.Select(t => t.InputTokens).ToArray();
        var output = turns.Select(t => t.OutputTokens).ToArray();
        var reasoning = turns.Select(t => t.ReasoningTokens).ToArray();

        double cumA = 0, cumD = 0;
        var cumAiu = turns.Select(t => cumA += t.Aiu).ToArray();
        var cumSec = turns.Select(t => cumD += t.DurationMs / 1000.0).ToArray();

        await JS.InvokeVoidAsync("copilotCharts.renderTokensPerTurn", "chartTokens", labels, input, output, reasoning);
        await JS.InvokeVoidAsync("copilotCharts.renderCumulative", "chartCumulative", labels, cumAiu, cumSec);

        if (_analysis.ContextSamples.Count > 1)
        {
            var cl = _analysis.ContextSamples.Select((_, i) => (i + 1).ToString()).ToArray();
            var cur = _analysis.ContextSamples.Select(s => s.CurrentTokens).ToArray();
            var lim = _analysis.ContextSamples.Select(s => s.TokenLimit).ToArray();
            await JS.InvokeVoidAsync("copilotCharts.renderContext", "chartContext", cl, cur, lim);
        }
    }

    private static RenderFragment Stat(string label, string value, string? tip = null) => builder =>
    {
        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "col");
        builder.OpenElement(2, "div");
        builder.AddAttribute(3, "class", tip is null ? "border rounded p-2 h-100" : "border rounded p-2 h-100 stat-card");
        if (tip is not null) { builder.AddAttribute(4, "data-tip", tip); }
        builder.OpenElement(5, "div");
        builder.AddAttribute(6, "class", "text-muted small");
        builder.AddContent(7, label);
        builder.CloseElement();
        builder.OpenElement(8, "div");
        builder.AddAttribute(9, "class", "fs-6 fw-semibold");
        builder.AddContent(10, value);
        builder.CloseElement();
        builder.CloseElement();
        builder.CloseElement();
    };

    private static string AlertClass(string severity) => severity switch
    {
        "high" => "alert-danger",
        "warning" => "alert-warning",
        _ => "alert-info",
    };

    private static string Truncate(string? s, int n)
    {
        if (string.IsNullOrEmpty(s)) return "";
        s = s.Replace('\n', ' ').Replace('\r', ' ');
        return s.Length <= n ? s : s[..n] + "…";
    }

    // Length-cap that preserves newlines (for <pre> result/reasoning blocks).
    private static string TruncateRaw(string? s, int n)
    {
        if (string.IsNullOrEmpty(s)) return "";
        return s.Length <= n ? s : s[..n] + "\n… (truncated)";
    }

    // Prefer the raw tool arguments; fall back to the command verb.
    private static string StepArgs(TurnStep step)
        => !string.IsNullOrWhiteSpace(step.Arguments) ? step.Arguments!
            : (step.Command ?? "");

    // Per-tool list of the most meaningful argument field(s) for a one-line preview.
    private static readonly Dictionary<string, string[]> PreviewKeys = new(StringComparer.OrdinalIgnoreCase)
    {
        ["edit"] = new[] { "path" },
        ["str_replace"] = new[] { "path" },
        ["create"] = new[] { "path" },
        ["view"] = new[] { "path" },
        ["read"] = new[] { "path" },
        ["powershell"] = new[] { "command", "description" },
        ["bash"] = new[] { "command", "description" },
        ["read_powershell"] = new[] { "shellId" },
        ["stop_powershell"] = new[] { "shellId" },
        ["grep"] = new[] { "pattern" },
        ["glob"] = new[] { "pattern" },
        ["web_fetch"] = new[] { "url" },
        ["web_search"] = new[] { "query" },
        ["task"] = new[] { "description", "name" },
        ["ask_user"] = new[] { "question" },
        ["store_memory"] = new[] { "fact", "subject" },
        ["vote_memory"] = new[] { "fact" },
        ["sql"] = new[] { "description", "query" },
    };

    // Build a compact one-line preview, surfacing the most important field per tool.
    private static string StepPreview(TurnStep step)
    {
        var args = StepArgs(step);
        if (string.IsNullOrWhiteSpace(args)) return "";
        var s = args.Trim();
        if (s.StartsWith('{'))
        {
            try
            {
                using var doc = System.Text.Json.JsonDocument.Parse(s);
                var root = doc.RootElement;
                if (PreviewKeys.TryGetValue(step.ToolName ?? "", out var keys))
                {
                    foreach (var k in keys)
                    {
                        if (root.TryGetProperty(k, out var v) && v.ValueKind == System.Text.Json.JsonValueKind.String)
                        {
                            var val = v.GetString();
                            if (!string.IsNullOrWhiteSpace(val)) return OneLine(val!);
                        }
                    }
                }
                // Generic fallback: first non-empty string property, shown as name: value.
                foreach (var p in root.EnumerateObject())
                {
                    if (p.Value.ValueKind == System.Text.Json.JsonValueKind.String)
                    {
                        var val = p.Value.GetString();
                        if (!string.IsNullOrWhiteSpace(val)) return OneLine($"{p.Name}: {val}");
                    }
                }
            }
            catch { /* not valid JSON — fall through to raw */ }
        }
        return OneLine(s);
    }

    private static string OneLine(string s)
    {
        s = s.Replace('\r', ' ').Replace('\n', ' ').Trim();
        return s.Length <= 140 ? s : s[..140] + "…";
    }

    // Pretty-print JSON arguments so the full payload is readable; raw text otherwise.
    private static string PrettyArgs(string args)
    {
        var s = args.Trim();
        if (s.StartsWith('{') || s.StartsWith('['))
        {
            try
            {
                using var doc = System.Text.Json.JsonDocument.Parse(s);
                return System.Text.Json.JsonSerializer.Serialize(doc.RootElement,
                    new System.Text.Json.JsonSerializerOptions
                    {
                        WriteIndented = true,
                        Encoder = System.Text.Encodings.Web.JavaScriptEncoder.UnsafeRelaxedJsonEscaping,
                    });
            }
            catch { /* not valid JSON — show raw */ }
        }
        return args;
    }

    private static string FormatDuration(double ms)
    {
        var t = TimeSpan.FromMilliseconds(ms);
        if (t.TotalHours >= 1) return $"{(int)t.TotalHours}h {t.Minutes}m";
        if (t.TotalMinutes >= 1) return $"{t.Minutes}m {t.Seconds}s";
        if (t.TotalSeconds >= 1) return $"{t.TotalSeconds:N1}s";
        return $"{(int)Math.Round(t.TotalMilliseconds)}ms";
    }
}
